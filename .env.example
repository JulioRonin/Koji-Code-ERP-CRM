# =============================================================================
# KOJI CODE ERP — Variables de entorno
# =============================================================================
# Copia este archivo como `.env.local` y rellena los valores.
# En Vercel: agrega cada variable en Project Settings → Environment Variables.
#
# La app funciona SIN Supabase configurado (usa datos mock como demo).
# En cuanto agregues VITE_SUPABASE_URL y VITE_SUPABASE_ANON_KEY,
# automáticamente cambia a datos reales.
# =============================================================================

# --- Supabase (opcional para demo, requerido para producción) ----------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- n8n webhooks (opcional, para automatizaciones) --------------------------
# URL del webhook n8n que recibe eventos de la cola automation_events
VITE_N8N_WEBHOOK_URL=
